@{
    ViewData["Title"] = "Discord Lite - Access Denied";
}

<div class="bg-dark text-white min-vh-100 d-flex align-items-center justify-content-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
                <div class="card bg-secondary bg-opacity-25 border-0 shadow-lg">
                    <div class="card-body p-4 p-md-5 text-center">
                        <!-- Warning Icon -->
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-25 rounded-circle mb-4" style="width: 100px; height: 100px;">
                            <i class="bi bi-shield-x display-3 text-danger"></i>
                        </div>

                        <!-- Header -->
                        <h1 class="text-white fw-bold mb-3">Access Denied</h1>

                        <!-- Message -->
                        <p class="text-secondary mb-4 lead">
                            Oops! You don't have permission to access this page.
                        </p>

                        <!-- Alert Box -->
                        <div class="alert bg-dark border border-secondary text-start mb-4" role="alert">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-info-circle text-info me-3 mt-1"></i>
                                <div>
                                    <h6 class="text-white mb-1">Why am I seeing this?</h6>
                                    <ul class="text-secondary small mb-0 ps-3">
                                        <li>You may not have the required permissions</li>
                                        <li>Your session may have expired</li>
                                        <li>This area is restricted to certain users</li>
                                        <li>You need to verify your account</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Error Code -->
                        <div class="bg-dark rounded p-3 mb-4">
                            <div class="row text-center">
                                <div class="col-4 border-end border-secondary">
                                    <span class="text-secondary small text-uppercase d-block">Error Code</span>
                                    <span class="text-white fw-bold">403</span>
                                </div>
                                <div class="col-4 border-end border-secondary">
                                    <span class="text-secondary small text-uppercase d-block">Status</span>
                                    <span class="text-danger fw-bold">Forbidden</span>
                                </div>
                                <div class="col-4">
                                    <span class="text-secondary small text-uppercase d-block">Time</span>
                                    <span class="text-white fw-bold">@DateTime.Now.ToString("HH:mm")</span>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mb-4">
                            <a asp-action="Index" asp-controller="Home" class="btn btn-primary btn-lg px-4">
                                <i class="bi bi-house me-2"></i>Go Home
                            </a>
                            <a asp-action="Login" asp-controller="Auth" class="btn btn-outline-light btn-lg px-4">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                            </a>
                        </div>

                        <!-- Back Link -->
                        <div class="mb-0">
                            <a href="javascript:history.back()" class="text-info text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i>Go back to previous page
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Help Section -->
                <div class="card bg-secondary bg-opacity-10 border-0 mt-4">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-25 rounded-circle" style="width: 50px; height: 50px;">
                                    <i class="bi bi-headset fs-4 text-primary"></i>
                                </div>
                            </div>
                            <div class="col">
                                <h6 class="text-white mb-1">Need Help?</h6>
                                <p class="text-secondary small mb-0">
                                    If you believe this is an error, please contact our support team.
                                </p>
                            </div>
                            <div class="col-auto">
                                <a href="#" class="btn btn-outline-primary btn-sm">
                                    Contact Support (Coming Soon..)
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="text-center mt-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary rounded-circle mb-2" style="width: 40px; height: 40px;">
                        <i class="bi bi-discord fs-5 text-white"></i>
                    </div>
                    <p class="text-secondary small mb-0">
                        Discord Lite &copy; @DateTime.Now.Year
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>