@using DiscordLite_DTO
@{
    ViewData["Title"] = "Discord Lite - Login";
}
@model LoginRequestDTO;


<div class="bg-dark text-white min-vh-100 d-flex align-items-center justify-content-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">
                <div class="card bg-secondary bg-opacity-25 border-0 shadow-lg">
                    <div class="card-body p-4 p-md-5">
                        <!-- Logo and Header -->
                        <div class="text-center mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center bg-primary rounded-circle mb-3" style="width: 60px; height: 60px;">
                                <i class="bi bi-discord fs-2 text-white"></i>
                            </div>
                            <h2 class="text-white fw-bold mb-1">Welcome back!</h2>
                            <p class="text-secondary mb-0">We're so excited to see you again!</p>
                        </div>

                        <!-- Login Form -->
                        <form asp-action="Login" asp-controller="Auth" method="post">
                            @Html.AntiForgeryToken()

                            <!-- Email or Username Field -->
                            <div class="mb-3">
                                <label asp-for="UsernameOrEmail" class="form-label text-secondary text-uppercase small fw-bold">
                                    Email or UserName <span class="text-danger">*</span>
                                </label>
                                <input asp-for="@Model.UsernameOrEmail" type="text"
                                       class="form-control bg-dark border-secondary text-white"
                                       name="UsernameOrEmail"
                                       required />
                                <span asp-validation-for="@Model.UsernameOrEmail" class="text-danger small"></span>
                            </div>

                            <!-- Password Field -->
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label text-secondary text-uppercase small fw-bold">
                                    Password <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <input asp-for="Password" type="password"
                                           class="form-control bg-dark border-secondary text-white border-end-0"
                                           name="Password"
                                           required />
                                    <button class="btn btn-dark border-secondary border-start-0" type="button" id="togglePassword">
                                        <i class="bi bi-eye text-secondary"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <!-- Forgot Password Link -->
                            <!-- Add Later -->
                            @* <div class="mb-3">
                                <a href="#" class="text-info text-decoration-none small">Forgot your password?</a>
                            </div> *@

                            <!-- Remember Me  -->
                            <!-- Add Later  -->
                            @* <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input bg-dark border-secondary"
                                           type="checkbox"
                                           id="rememberMe"
                                           name="RememberMe" />
                                    <label class="form-check-label text-secondary small" for="rememberMe">
                                        Remember me
                                    </label>
                                </div>
                            </div> *@

                            <!-- Validation Summary -->
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>
                            }
                            <!-- If password is wrong -->
                            @if (TempData["error"] != null)
                            {
                                <div class="alert alert-danger small py-2" role="alert">
                                    <i class="bi bi-exclamation-circle me-1"></i>
                                    @TempData["error"]
                                </div>
                            }
                            <!-- Submit Button -->
                            <div class="d-grid mb-3">
                                <button asp-controller="Auth" asp-action="Login" type="submit" class="btn btn-primary btn-lg fw-semibold">
                                    Log In
                                </button>
                            </div>

                            <!-- Register Link -->
                            <div class="text-start">
                                <span class="text-secondary small">Need an account? </span>
                                <a asp-action="Register" asp-controller="Auth" class="text-info text-decoration-none small">Register</a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Footer -->
                <div class="bg-dark text-white text-center mt-4">
                    <p class="text-secondary small mb-0">
                        <i class="bi bi-shield-check me-1"></i>
                        Protected by Discord Lite Security
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
    const passwordInput = document.getElementById('password');
    const icon = this.querySelector('i');

    if (passwordInput.type === 'password') {
    passwordInput.type = 'text';
    icon.classList.remove('bi-eye');
    icon.classList.add('bi-eye-slash');
    } else {
    passwordInput.type = 'password';
    icon.classList.remove('bi-eye-slash');
    icon.classList.add('bi-eye');
    }
    });
</script>
