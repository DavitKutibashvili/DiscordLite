@{
    Layout = null;
    ViewData["Title"] = "Discord Lite - Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-dark text-white">
    <div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">
                    <div class="card bg-secondary bg-opacity-25 border-0 shadow-lg">
                        <div class="card-body p-4 p-md-5">
                            <!-- Logo and Header -->
                            <div class="text-center mb-4">
                                <div class="d-inline-flex align-items-center justify-content-center bg-primary rounded-circle mb-3" style="width: 60px; height: 60px;">
                                    <i class="bi bi-discord fs-2 text-white"></i>
                                </div>
                                <h2 class="text-white fw-bold mb-1">Create an account</h2>
                                <p class="text-secondary mb-0">Join the Discord Lite community</p>
                            </div>

                            <!-- Register Form -->
                            <form asp-action="Register" asp-controller="Account" method="post">
                                @Html.AntiForgeryToken()

                                <!-- Email Field -->
                                <div class="mb-3">
                                    <label for="email" class="form-label text-secondary text-uppercase small fw-bold">
                                        Email <span class="text-danger">*</span>
                                    </label>
                                    <input type="email"
                                           class="form-control bg-dark border-secondary text-white"
                                           id="email"
                                           name="Email"
                                           placeholder="Enter your email"
                                           required />
                                    <span @* asp-validation-for="Email" *@ class="text-danger small"></span>
                                </div>

                                <!-- Display Name Field -->
                                <div class="mb-3">
                                    <label for="displayName" class="form-label text-secondary text-uppercase small fw-bold">
                                        Display Name <span class="text-danger">*</span>
                                    </label>
                                    <input type="text"
                                           class="form-control bg-dark border-secondary text-white"
                                           id="displayName"
                                           name="DisplayName"
                                           placeholder="How should we call you?"
                                           required />
                                    <span @* asp-validation-for="DisplayName" *@ class="text-danger small"></span>
                                </div>

                                <!-- Username Field -->
                                <div class="mb-3">
                                    <label for="username" class="form-label text-secondary text-uppercase small fw-bold">
                                        Username <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-dark border-secondary text-secondary">@@</span>
                                        <input type="text"
                                               class="form-control bg-dark border-secondary text-white"
                                               id="username"
                                               name="Username"
                                               placeholder="Choose a unique username"
                                               required />
                                    </div>
                                    <span @* asp-validation-for="Username" *@ class="text-danger small"></span>
                                </div>

                                <!-- Password Field -->
                                <div class="mb-3">
                                    <label for="password" class="form-label text-secondary text-uppercase small fw-bold">
                                        Password <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input type="password"
                                               class="form-control bg-dark border-secondary text-white border-end-0"
                                               id="password"
                                               name="Password"
                                               placeholder="Create a strong password"
                                               required />
                                        <button class="btn btn-dark border-secondary border-start-0" type="button" id="togglePassword">
                                            <i class="bi bi-eye text-secondary"></i>
                                        </button>
                                    </div>
                                    <div class="form-text text-secondary small">
                                        Must be at least 8 characters with uppercase, lowercase, and numbers
                                    </div>
                                    <span @* asp-validation-for="Password" *@ class="text-danger small"></span>
                                </div>

                                <!-- Confirm Password Field -->
                                <div class="mb-3">
                                    <label for="confirmPassword" class="form-label text-secondary text-uppercase small fw-bold">
                                        Confirm Password <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input type="password"
                                               class="form-control bg-dark border-secondary text-white border-end-0"
                                               id="confirmPassword"
                                               name="ConfirmPassword"
                                               placeholder="Re-enter your password"
                                               required />
                                        <button class="btn btn-dark border-secondary border-start-0" type="button" id="toggleConfirmPassword">
                                            <i class="bi bi-eye text-secondary"></i>
                                        </button>
                                    </div>
                                    <span @* asp-validation-for="ConfirmPassword" *@ class="text-danger small"></span>
                                </div>

                                <!-- Date of Birth -->
                                <div class="mb-3">
                                    <label class="form-label text-secondary text-uppercase small fw-bold">
                                        Date of Birth <span class="text-danger">*</span>
                                    </label>
                                    <div class="row g-2">
                                        <div class="col-4">
                                            <select class="form-select bg-dark border-secondary text-white" id="birthMonth" name="BirthMonth" required>
                                                <option value="" selected disabled>Month</option>
                                                <option value="1">January</option>
                                                <option value="2">February</option>
                                                <option value="3">March</option>
                                                <option value="4">April</option>
                                                <option value="5">May</option>
                                                <option value="6">June</option>
                                                <option value="7">July</option>
                                                <option value="8">August</option>
                                                <option value="9">September</option>
                                                <option value="10">October</option>
                                                <option value="11">November</option>
                                                <option value="12">December</option>
                                            </select>
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select bg-dark border-secondary text-white" id="birthDay" name="BirthDay" required>
                                                <option value="" selected disabled>Day</option>
                                                @for (int i = 1; i <= 31; i++)
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-4">
                                            <select class="form-select bg-dark border-secondary text-white" id="birthYear" name="BirthYear" required>
                                                <option value="" selected disabled>Year</option>
                                                @for (int i = DateTime.Now.Year - 13; i >= DateTime.Now.Year - 100; i--)
                                                {
                                                    <option value="@i">@i</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <span @* asp-validation-for="DateOfBirth" *@ class="text-danger small"></span>
                                </div>

                                <!-- Terms and Privacy Checkbox -->
                                <div class="mb-4">
                                    <div class="form-check">
                                        <input class="form-check-input bg-dark border-secondary"
                                               type="checkbox"
                                               id="agreeTerms"
                                               name="AgreeTerms"
                                               required />
                                        <label class="form-check-label text-secondary small" for="agreeTerms">
                                            I have read and agree to Discord Lite's
                                            <a href="#" class="text-info text-decoration-none">Terms of Service</a> and
                                            <a href="#" class="text-info text-decoration-none">Privacy Policy</a>
                                        </label>
                                    </div>
                                </div>

                                <!-- Email Updates Checkbox -->
                                <div class="mb-4">
                                    <div class="form-check">
                                        <input class="form-check-input bg-dark border-secondary"
                                               type="checkbox"
                                               id="emailUpdates"
                                               name="EmailUpdates" />
                                        <label class="form-check-label text-secondary small" for="emailUpdates">
                                            (Optional) I want to receive updates, tips, and offers from Discord Lite
                                        </label>
                                    </div>
                                </div>

                                <!-- Validation Summary -->
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                                <!-- Submit Button -->
                                <div class="d-grid mb-3">
                                    <button type="submit" class="btn btn-primary btn-lg fw-semibold">
                                        Continue
                                    </button>
                                </div>

                                <!-- Login Link -->
                                <div class="text-start">
                                    <a asp-action="Login" asp-controller="Auth" class="text-info text-decoration-none small">Already have an account?</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="text-center mt-4">
                        <p class="text-secondary small mb-0">
                            <i class="bi bi-shield-check me-1"></i>
                            Your data is safe with us
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    <script>
        function setupPasswordToggle(toggleId, inputId) {
        document.getElementById(toggleId).addEventListener('click', function () {
        const passwordInput = document.getElementById(inputId);
        const icon = this.querySelector('i');

        if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
        } else {
        passwordInput.type = 'password';
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
        }
        });
        }

        setupPasswordToggle('togglePassword', 'password');
        setupPasswordToggle('toggleConfirmPassword', 'confirmPassword');
    </script>
</body>
</html>