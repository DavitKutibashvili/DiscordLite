@using System.Security.Claims
@using DiscordLite_Utility
@model DiscordLite_WEB.ViewModels.OpenDMChatVM
@{
    ViewData["Title"] = Model.OtherDisplayName;
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/OpenChat.css" />

<div class="chat-shell">

    <!-- Header -->
    <div class="chat-header">
        <div class="avatar">
            <img src="@SD.GetImageUrl(Model.OtherAvatarUrl)" alt="Avatar" class="dl-avatar" />
            <div class="status-dot" data-user-id="@Model.OtherUserId" id="otherStatusDot"></div>
        </div>
        <div class="user-info">
            <div class="display-name">@Model.OtherDisplayName</div>
            <div class="username">&#64;@Model.OtherUserName</div>
        </div>
        <div class="header-actions">
            <button title="Search"><i class="bi bi-search"></i></button>
            <a asp-action="Index" class="btn p-0" style="color:var(--dl-muted);" title="Back to DMs">
                <i class="bi bi-x-lg" style="font-size:18px;"></i>
            </a>
        </div>
    </div>

    <!-- Messages -->
    <div class="message-list" id="messageList">
        <div class="system-msg">
            <i class="bi bi-lock-fill me-1"></i>
            This is the beginning of your direct message history with <strong>@Model.OtherDisplayName</strong>.
        </div>
        <!-- messages injected here by JS -->
    </div>

    <!-- Typing indicator -->
    <div class="typing-indicator px-4" id="typingIndicator">
        <div class="typing-dots"><span></span><span></span><span></span></div>
        <span id="typingLabel">@Model.OtherDisplayName is typing…</span>
    </div>

    <!-- Input -->
    <div class="chat-input-bar">
        <div class="input-wrapper">
            <textarea class="chat-input" id="messageInput"
                      placeholder="Message @@@Model.OtherDisplayName"
                      rows="1"></textarea>
            <button class="send-btn" id="sendBtn" title="Send" disabled>
                <i class="bi bi-send-fill" style="font-size:14px;"></i>
            </button>
        </div>
    </div>
</div>

<div class="conn-toast" id="connToast"></div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const CHAT_ID      = @Model.ChatId;
        const CURRENT_USER = "@User.FindFirstValue(ClaimTypes.NameIdentifier)";
        const OTHER_USER   = "@Model.OtherUserId";
        const OTHER_NAME   = "@Model.OtherDisplayName";
    </script>
    <script src="~/js/DMChat.js"></script>
}
