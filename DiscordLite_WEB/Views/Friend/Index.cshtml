@using DiscordLite_Utility
@using DiscordLite_WEB.ViewModels
@{
    ViewData["Title"] = "Discord Lite - Friends";
}
@model FriendshipVM



<div id="friends-page">
    <div style="margin: 0 10%;">
        <h1 class="dl-page-title">Friends</h1>

        @if (TempData["success"] != null)
        {
            <div class="alert dl-alert dl-alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["success"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="alert dl-alert dl-alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                @TempData["error"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }

        <p class="dl-section-label">Add Friend</p>
        <div class="dl-add-friend-box">
            <form asp-action="SendFriendRequest" method="post">
                <div class="dl-input-group">
                    <input type="text" name="userName" class="dl-input" placeholder="Enter a username" required />
                    <button type="submit" class="dl-btn-primary">Send Request</button>
                </div>
                <p>You can add friends with their exact username.</p>
            </form>
        </div>

        @if (Model.PendingFriendRequests.Count > 0)
        {
            <p class="dl-section-label">Pending — @Model.PendingFriendRequests.Count</p>
            @foreach (var request in Model.PendingFriendRequests)
            {
                <div class="dl-friend-card">
                    <div class="dl-avatar-wrap">
                        <img src="@SD.GetImageUrl(request.SenderAvatarUrl!)" alt="Avatar" class="dl-avatar" />
                    </div>
                    <div class="dl-friend-info">
                        <div class="dl-friend-name">@request.SenderUserName</div>
                        <div class="dl-request-label">Incoming friend request</div>
                    </div>
                    <div class="dl-actions">
                        <form asp-action="AcceptFriendRequest" method="post">
                            <input type="hidden" name="id" value="@request.FriendshipId" />
                            <button type="submit" class="dl-icon-btn dl-icon-btn-success" title="Accept">
                                <i class="bi bi-check-lg"></i>
                            </button>
                        </form>
                        <form asp-action="DeclineFriendRequest" method="post">
                            <input type="hidden" name="id" value="@request.FriendshipId" />
                            <button type="submit" class="dl-icon-btn dl-icon-btn-outline" title="Decline">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
            <hr class="dl-divider" />
        }

        <p class="dl-section-label">Online — @Model.Friends.Count</p>
        @foreach (var friend in Model.Friends)
        {
            <div class="dl-friend-card">
                <div class="dl-avatar-wrap">
                    <img src="@SD.GetImageUrl(friend.FriendAvatarUrl)" alt="Avatar" class="dl-avatar" />
                    <span class="dl-presence" data-user-id="@friend.FriendId"></span>
                </div>
                <div class="dl-friend-info">
                    <div class="dl-friend-name">@friend.FriendDisplayName</div>
                    <div class="dl-friend-sub">@friend.FriendUserName</div>
                </div>

                <div class="dl-actions friend-actions">
                    <a asp-action="OpenOrCreateChat" asp-controller="Chat" asp-route-otherUserId="@friend.FriendId" class="dl-btn-sm dl-btn-msg">Message</a>
                    <button type="button" class="dl-btn-sm dl-btn-remove" onclick="showRemoveConfirm(this)">Remove</button>
                </div>

                <div class="dl-actions remove-confirm" style="display:none; align-items:center; gap:0.4rem;">
                    <span class="dl-confirm-text">Sure?</span>
                    <form asp-action="RemoveFriend" asp-route-id="@friend.FriendshipId" method="post">
                        <button type="submit" class="dl-btn-sm dl-btn-confirm-yes">Yes</button>
                    </form>
                    <button type="button" class="dl-btn-sm dl-btn-confirm-no" onclick="cancelRemoveConfirm(this)">No</button>
                </div>
            </div>
        }
    </div>
</div>

<nav class="bottom-nav">
    <div class="nav-inner">
        <a asp-controller="Chat" class="nav-item">
            <i class="bi bi-chat-dots"></i>
            <span>Chats</span>
        </a>
        <a class="nav-item active">
            <i class="bi bi-people-fill"></i>
            <span>Friends</span>
        </a>
        <a asp-controller="Server" class="nav-item">
            <i class="bi bi-hdd-stack"></i>
            <span>Servers</span>
        </a>
        <a asp-controller="Setting" class="nav-item">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </div>
</nav>

@section Scripts {
    <script>
        function showRemoveConfirm(btn) {
            var card = btn.closest('.dl-friend-card');
            card.querySelector('.friend-actions').style.display = 'none';
            var confirm = card.querySelector('.remove-confirm');
            confirm.style.display = 'flex';
        }

        function cancelRemoveConfirm(btn) {
            var card = btn.closest('.dl-friend-card');
            card.querySelector('.remove-confirm').style.display = 'none';
            card.querySelector('.friend-actions').style.display = 'flex';
        }
    </script>
}
