@{
    ViewData["Title"] = "Discord Lite - Friends";
}

<div id="friends-page" class="p-3">
    <h1 class="h4 fw-bold mb-4">Friends</h1>
    <div class="d-flex flex-column align-items-center gap-2">
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center gap-3" style="width:80%;">
            <div class="position-relative">
                <div class="rounded-circle bg-success d-flex align-items-center justify-content-center fw-bold" style="width:42px;height:42px;">A</div>
                <span class="position-absolute bottom-0 end-0 bg-success rounded-circle border border-dark" style="width:12px;height:12px;"></span>
            </div>
            <div class="flex-grow-1">
                <div class="fw-semibold">Alex</div>
                <small class="text-secondary">alex_dev</small>
            </div>
            <button class="btn btn-primary btn-sm">Message</button>
        </div>
    </div>
</div>
<nav class="navbar fixed-bottom bg-dark border-top border-secondary">
    <div class="container">
        <div class="d-flex justify-content-around align-items-center w-100">
            <a asp-action="Index" class="btn btn-dark d-flex flex-column align-items-center text-white" data-page="chats">
                <i class="bi bi-chat-dots fs-5"></i>
                <small>Chats</small>
            </a>
            <a class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="friends">
                <i class="bi bi-people fs-5"></i>
                <small>Friends</small>
            </a>
            <a asp-action="Servers" class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="servers">
                <i class="bi bi-hdd-stack fs-5"></i>
                <small>Servers</small>
            </a>
            <a asp-action="Settings" class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="settings">
                <i class="bi bi-gear fs-5"></i>
                <small>Settings</small>
            </a>
        </div>
    </div>
</nav>
