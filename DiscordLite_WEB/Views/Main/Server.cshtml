@using DiscordLite_DTO
@using DiscordLite_Utility
@{
    ViewData["Title"] = "Discord Lite - " + Model.Name;
    Layout = "_Layout";
}
@model ServerDTO

<link rel="stylesheet" href="~/css/Server.css" />

<!-- ===== DESKTOP LAYOUT ===== -->
<div class="server-shell">

    <!-- Left: Channel Sidebar -->
    <div class="server-sidebar">
        <div class="server-sidebar-header">
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-action="Servers" style="color:var(--dl-muted); text-decoration:none; font-size:1.1rem; line-height:1;">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <div class="server-name">@Model.Name</div>
            </div>
            <div class="server-meta">Created @Model.CreatedAt.ToString("MMM d, yyyy")</div>
        </div>

        <div class="sidebar-scrollable">
            <div class="sidebar-section">
                <div class="sidebar-section-label">
                    Channels
                    <button onclick="toggleAddChannel()" title="Add channel"><i class="bi bi-plus-lg"></i></button>
                </div>
                <div class="add-channel-form" id="addChannelForm">
                    <form asp-action="CreateChannel" asp-route-serverId="@Model.Id" method="post" class="d-flex gap-1 w-100">
                        <input type="text" name="name" placeholder="channel-name" required />
                        <button type="submit">Add</button>
                    </form>
                </div>

                @foreach (var channel in Model.Channels)
                {
                    <div class="channel-item @(channel.Id == (int?)ViewBag.SelectedChannelId ? "active" : "")">
                        <a asp-action="Server" asp-route-id="@Model.Id" asp-route-channelId="@channel.Id">
                            <i class="bi bi-hash"></i>
                            <span class="channel-name">@channel.Name</span>
                        </a>
                        <a asp-action="DeleteChannel" asp-route-id="@channel.Id" class="ch-delete" title="Delete"><i class="bi bi-trash"></i></a>
                    </div>
                }
            </div>
        </div>

        <div class="sidebar-footer">
            <form asp-action="LeaveServer" asp-route-id="@Model.Id" method="post" style="flex:1;">
                <button type="submit" class="btn-leave">Leave</button>
            </form>
            <form asp-action="DeleteServer" asp-route-id="@Model.Id" method="post" style="flex:1;">
                <button type="submit" class="btn-delete-server">Delete</button>
            </form>
        </div>
    </div>

    <!-- Center: Chat Area -->
    <div class="server-main">
        <div class="main-header">
            <i class="bi bi-hash" style="color: var(--dl-muted);"></i>
            <span class="channel-title">@ViewBag.SelectedChannelName</span>
            <div class="header-actions">
                <button title="Search"><i class="bi bi-search"></i></button>
                <button title="Members" onclick="toggleMembersSidebar()"><i class="bi bi-people"></i></button>
            </div>
        </div>

        @if (ViewBag.SelectedChannelId != null)
        {
            <div class="message-list" id="messageList">
                <div class="system-msg">
                    <i class="bi bi-hash me-1"></i>
                    Welcome to <strong>#@ViewBag.SelectedChannelName</strong>. This is the beginning of the channel.
                </div>
            </div>

            <div class="typing-indicator px-4" id="typingIndicator">
                <div class="typing-dots"><span></span><span></span><span></span></div>
                <span id="typingLabel"></span>
            </div>

            <div class="chat-input-bar">
                <div class="input-wrapper">
                    <textarea class="chat-input" id="messageInput"
                              placeholder="Message #@ViewBag.SelectedChannelName"
                              rows="1"></textarea>
                    <button class="send-btn" id="sendBtn" title="Send" disabled>
                        <i class="bi bi-send-fill" style="font-size:14px;"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="main-content">
                <i class="bi bi-hash"></i>
                <div style="font-weight: 600; color: var(--dl-text);">Select a channel</div>
                <div>Pick a channel from the left to start chatting</div>
            </div>
        }
    </div>

    <!-- Right: Members Sidebar -->
    <div class="members-sidebar" id="membersSidebar" style="display:none;">
        <div class="members-sidebar-header">Members — @Model.Members.Count</div>
        <div class="members-list">
            @foreach (var member in Model.Members.OrderByDescending(m => m.IsOwner))
            {
                <div class="member-item">
                    <div class="member-avatar-wrap">
                        <img src="@SD.GetImageUrl(member.AvatarUrl!)" alt="Avatar" class="dl-avatar" />
                        <span class="member-presence" data-user-id="@member.UserId"></span>
                    </div>
                    <div class="member-info">
                        <div class="member-name">
                            @member.DisplayName
                            @if (member.IsOwner)
                            {
                                <i class="bi bi-shield-fill ms-1" style="color: var(--dl-accent); font-size: 0.65rem;" title="Owner"></i>
                            }
                        </div>
                        <div class="member-sub">@member.UserName</div>
                    </div>
                </div>
            }
        </div>

        <div class="invite-bar">
            <i class="bi bi-link-45deg" style="color: var(--dl-muted); flex-shrink:0;"></i>
            <span class="invite-code-text" id="inviteCodeText">@Model.InviteCode</span>
            <form asp-action="GenerateInviteCode" asp-route-id="@Model.Id" method="post">
                <button type="submit" title="Regenerate"><i class="bi bi-arrow-clockwise"></i></button>
            </form>
            <button onclick="copyInvite()" title="Copy"><i class="bi bi-clipboard" id="copyIcon"></i></button>
        </div>
    </div>

</div>

<!-- ===== MOBILE LAYOUT ===== -->
<!-- ===== MOBILE LAYOUT ===== -->
<div class="mobile-wrapper" style="background: var(--dl-bg);">

    <!-- Server Info Header -->
    <div class="mobile-server-info" id="mobileServerInfo">
        <div class="mobile-server-card">
            <a asp-action="Servers" style="color:var(--dl-muted); text-decoration:none; font-size:1.2rem; flex-shrink:0;">
                <i class="bi bi-chevron-left"></i>
            </a>
            <div class="mobile-server-icon">@Model.Name.Substring(0, 1).ToUpper()</div>
            <div>
                <div style="font-size:1rem; font-weight:700; color:var(--dl-text);">@Model.Name</div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div style="font-size:0.8rem; color:var(--dl-muted);">@Model.Description</div>
                }
                <div style="font-size:0.75rem; color:var(--dl-muted);">Created @Model.CreatedAt.ToString("MMM d, yyyy")</div>
            </div>
        </div>
        <div style="display:flex; align-items:center; gap:0.5rem; background:var(--dl-input-bg); border-radius:8px; padding:0.5rem 0.75rem;">
            <i class="bi bi-link-45deg" style="color:var(--dl-muted);"></i>
            <span style="flex:1; font-size:0.8rem; color:var(--dl-muted); font-family:monospace;">@Model.InviteCode</span>
            <form asp-action="GenerateInviteCode" asp-route-id="@Model.Id" method="post" style="margin:0;">
                <button type="submit" style="background:none;border:none;color:var(--dl-muted);cursor:pointer;padding:2px 4px;"><i class="bi bi-arrow-clockwise"></i></button>
            </form>
            <button onclick="copyInvite()" style="background:none;border:none;color:var(--dl-muted);cursor:pointer;padding:2px 4px;"><i class="bi bi-clipboard" id="copyIconMobile"></i></button>
        </div>
    </div>

    <!-- Tabs -->
    <div class="mobile-tabs" id="mobileTabs">
        <button class="mobile-tab active" onclick="showMobileTab('channels', this)">
            <i class="bi bi-hash me-1"></i>Channels
        </button>
        <button class="mobile-tab" onclick="showMobileTab('members', this)">
            <i class="bi bi-people me-1"></i>Members
        </button>
    </div>

    <!-- Mobile: Channels Panel -->
    <div class="mobile-panel" id="mobile-channels">
        <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1rem; background:var(--dl-surface); border-bottom:1px solid var(--dl-border);">
            <span style="font-size:0.7rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--dl-muted);">Channels</span>
            <button onclick="toggleMobileAddChannel()" style="background:none;border:none;color:var(--dl-muted);cursor:pointer;font-size:1rem;"><i class="bi bi-plus-lg"></i></button>
        </div>
        <div id="mobileAddChannelForm" style="display:none; padding:0.75rem 1rem; background:var(--dl-surface); border-bottom:1px solid var(--dl-border);">
            <form asp-action="CreateChannel" asp-route-serverId="@Model.Id" method="post" class="d-flex gap-2">
                <input type="text" name="name" class="dl-input" placeholder="channel-name" required style="flex:1;" />
                <button type="submit" class="dl-btn-primary">Add</button>
            </form>
        </div>

        @foreach (var channel in Model.Channels)
        {
            <div class="mobile-channel-item">
                <button onclick="openMobileChat(@channel.Id, '@channel.Name')"
                        style="display:flex; align-items:center; gap:0.75rem; flex:1; background:none; border:none; text-align:left; padding:0; cursor:pointer; color:inherit;">
                    <i class="bi bi-hash" style="color:var(--dl-muted);"></i>
                    <span style="flex:1; color:var(--dl-text); font-size:0.9rem;">@channel.Name</span>
                </button>
                <a asp-action="DeleteChannel" asp-route-id="@channel.Id" style="opacity:1; color:var(--dl-muted); margin-right:0.5rem;">
                    <i class="bi bi-trash"></i>
                </a>
                <i class="bi bi-chevron-right" style="color:var(--dl-muted);"></i>
            </div>
        }
    </div>

    <!-- Mobile: Members Panel -->
    <div class="mobile-panel" id="mobile-members" style="display:none;">
        @foreach (var member in Model.Members.OrderByDescending(m => m.IsOwner))
        {
            <div class="mobile-member-item">
                <div class="member-avatar-wrap">
                    <img src="@SD.GetImageUrl(member.AvatarUrl!)" alt="Avatar" class="dl-avatar" />
                    <span class="member-presence" data-user-id="@member.UserId"></span>
                </div>
                <div class="member-info">
                    <div class="member-name">
                        @member.DisplayName
                        @if (member.IsOwner)
                        {
                            <i class="bi bi-shield-fill ms-1" style="color:var(--dl-accent);font-size:0.65rem;"></i>
                        }
                    </div>
                    <div class="member-sub">@member.UserName</div>
                </div>
                <div class="mobile-member-actions">
                    <button class="dl-icon-btn dl-icon-btn-outline" title="Add friend" style="width:32px;height:32px;">
                        <i class="bi bi-person-plus"></i>
                    </button>
                    <form asp-action="RemoveMember" asp-route-serverId="@Model.Id" asp-route-userId="@member.UserId" method="post">
                        <button type="submit" class="dl-icon-btn dl-icon-btn-danger" title="Remove" style="width:32px;height:32px;">
                            <i class="bi bi-person-x"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
        <div style="padding:1rem; display:flex; gap:0.75rem; border-top:1px solid var(--dl-border); margin-top:0.5rem;">
            <form asp-action="LeaveServer" asp-route-id="@Model.Id" method="post" style="flex:1;">
                <button type="submit" class="dl-btn-primary w-100" style="background:transparent;border:1px solid var(--dl-border);color:var(--dl-muted);">
                    <i class="bi bi-box-arrow-left me-1"></i>Leave
                </button>
            </form>
            <form asp-action="DeleteServer" asp-route-id="@Model.Id" method="post" style="flex:1;">
                <button type="submit" class="dl-btn-primary w-100" style="background:transparent;border:1px solid var(--dl-danger);color:var(--dl-danger);">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </form>
        </div>
    </div>

    <!-- Mobile: Chat Panel (hidden until channel selected) -->
    <div id="mobileChatPanel" style="display:none; flex-direction:column; height:calc(100vh - 0px); background:var(--dl-bg);">
        <div style="display:flex; align-items:center; gap:0.75rem; padding:0.75rem 1rem; background:var(--dl-surface); border-bottom:1px solid var(--dl-border); flex-shrink:0;">
            <button onclick="closeMobileChat()" style="background:none;border:none;color:var(--dl-muted);cursor:pointer;font-size:1.1rem;padding:0;">
                <i class="bi bi-chevron-left"></i>
            </button>
            <i class="bi bi-hash" style="color:var(--dl-muted);"></i>
            <span id="mobileChatChannelName" style="font-size:0.95rem; font-weight:700; color:var(--dl-text);"></span>
        </div>

        <div class="message-list" id="mobileMessageList">
            <div class="system-msg">
                <i class="bi bi-hash me-1"></i>
                Welcome to <strong>#<span id="mobileChatChannelNameMsg"></span></strong>. This is the beginning of the channel.
            </div>
        </div>

        <div class="typing-indicator px-3" id="mobileTypingIndicator">
            <div class="typing-dots"><span></span><span></span><span></span></div>
            <span id="mobileTypingLabel"></span>
        </div>

        <div class="chat-input-bar">
            <div class="input-wrapper">
                <textarea class="chat-input" id="mobileMessageInput"
                          placeholder="Message..."
                          rows="1"></textarea>
                <button class="send-btn" id="mobileSendBtn" title="Send" disabled>
                    <i class="bi bi-send-fill" style="font-size:14px;"></i>
                </button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function toggleAddChannel() {
            const f = document.getElementById('addChannelForm');
            f.classList.toggle('visible');
        }

        function toggleMobileAddChannel() {
            const f = document.getElementById('mobileAddChannelForm');
            f.style.display = f.style.display === 'none' ? 'flex' : 'none';
        }

        function toggleMembersSidebar() {
            const s = document.getElementById('membersSidebar');
            s.style.display = s.style.display === 'none' ? 'flex' : 'none';
        }

        function showMobileTab(tab, btn) {
            document.querySelectorAll('.mobile-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('mobile-channels').style.display = tab === 'channels' ? 'block' : 'none';
            document.getElementById('mobile-members').style.display = tab === 'members' ? 'block' : 'none';
        }

        function copyInvite() {
            const code = document.getElementById('inviteCodeText')?.textContent.trim() ?? 'ABC123XYZ';
            navigator.clipboard.writeText(code).then(() => {
                const icon = document.getElementById('copyIcon');
                const iconM = document.getElementById('copyIconMobile');
                if (icon) icon.className = 'bi bi-clipboard-check';
                if (iconM) iconM.className = 'bi bi-clipboard-check';
                setTimeout(() => {
                    if (icon) icon.className = 'bi bi-clipboard';
                    if (iconM) iconM.className = 'bi bi-clipboard';
                }, 2000);
            });
        }

        function openMobileChat(channelId, channelName) {
            document.getElementById('mobileServerInfo').style.display = 'none';
            document.getElementById('mobileTabs').style.display = 'none';
            document.getElementById('mobile-channels').style.display = 'none';
            document.getElementById('mobile-members').style.display = 'none';
            document.getElementById('mobileChatChannelName').textContent = channelName;
            document.getElementById('mobileChatChannelNameMsg').textContent = channelName;
            document.getElementById('mobileMessageInput').placeholder = 'Message #' + channelName;
            document.getElementById('mobileChatPanel').style.display = 'flex';
        }

        function closeMobileChat() {
            document.getElementById('mobileChatPanel').style.display = 'none';
            document.getElementById('mobileServerInfo').style.display = 'flex';
            document.getElementById('mobileTabs').style.display = 'flex';
            document.getElementById('mobile-channels').style.display = 'block';
            document.getElementById('mobile-members').style.display = 'none';
            // reset tabs
            document.querySelectorAll('.mobile-tab').forEach((t, i) => {
                t.classList.toggle('active', i === 0);
            });
        }
                

        // SignalR presence integration point
        // data-user-id attributes on .member-presence dots are ready
        // Same pattern as Friends page
    </script>
}
