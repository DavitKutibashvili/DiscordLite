@{
    ViewData["Title"] = "Discord Lite - Servers";
}

<div id="friends-page">
    <div style="margin: 0 10%;">
        <h1 class="dl-page-title">Servers</h1>

        <p class="dl-section-label">Your Servers</p>

        <!-- Create / Join actions -->
        <div class="d-flex gap-2 mb-4">
            <button class="dl-btn-primary flex-grow-1">
                <i class="bi bi-plus-lg me-1"></i>Create Server
            </button>
            <button class="dl-btn-primary flex-grow-1" style="background: var(--dl-surface); border: 1px solid var(--dl-border); color: var(--dl-text);">
                <i class="bi bi-link-45deg me-1"></i>Join via Invite
            </button>
        </div>

        <!-- Placeholder server card -->
        <div class="dl-friend-card">
            <div class="dl-avatar-wrap">
                <div class="dl-avatar d-flex align-items-center justify-content-center fw-bold" style="background: #ed4245; color: #fff; border-radius: 30%;">
                    G
                </div>
            </div>
            <div class="dl-friend-info">
                <div class="dl-friend-name">Gaming Hub</div>
                <div class="dl-friend-sub">128 members</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

    </div>
</div>

<nav class="bottom-nav">
    <div class="nav-inner">
        <a asp-action="Index" class="nav-item">
            <i class="bi bi-chat-dots"></i>
            <span>Chats</span>
        </a>
        <a asp-action="Friends" class="nav-item">
            <i class="bi bi-people-fill"></i>
            <span>Friends</span>
        </a>
        <a class="nav-item active">
            <i class="bi bi-hdd-stack"></i>
            <span>Servers</span>
        </a>
        <a asp-action="Settings" class="nav-item">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </div>
</nav>