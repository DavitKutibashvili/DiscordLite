@{
    ViewData["Title"] = "Discord Lite - Settings";
}

<div id="settings-page" class="p-3">
    <h1 class="h4 fw-bold mb-4">Settings</h1>
    <div class="bg-secondary bg-opacity-25 rounded-3 p-3 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center fw-bold" style="width:52px;height:52px;font-size:1.2rem;">J</div>
            <div>
                <div class="fs-5 fw-semibold">John</div>
                <small class="text-secondary">john_doe</small>
            </div>
        </div>
    </div>
    <div class="d-flex flex-column gap-2 mb-4">
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center justify-content-between">
            <span class="fw-medium">Account</span>
            <i class="bi bi-chevron-right text-secondary"></i>
        </div>
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center justify-content-between">
            <span class="fw-medium">Notifications</span>
            <i class="bi bi-chevron-right text-secondary"></i>
        </div>
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center justify-content-between">
            <span class="fw-medium">Privacy</span>
            <i class="bi bi-chevron-right text-secondary"></i>
        </div>
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center justify-content-between">
            <span class="fw-medium">Appearance</span>
            <i class="bi bi-chevron-right text-secondary"></i>
        </div>
        <div class="bg-secondary bg-opacity-25 rounded-3 p-3 d-flex align-items-center justify-content-between">
            <span class="fw-medium">About</span>
            <i class="bi bi-chevron-right text-secondary"></i>
        </div>
    </div>
    <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger w-100 py-2 fw-medium">Log Out</a>
</div>
<nav class="navbar fixed-bottom bg-dark border-top border-secondary">
    <div class="container">
        <div class="d-flex justify-content-around align-items-center w-100">
            <a asp-action="Index" class="btn btn-dark d-flex flex-column align-items-center text-white" data-page="chats">
                <i class="bi bi-chat-dots fs-5"></i>
                <small>Chats</small>
            </a>
            <a asp-action="Friends" class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="friends">
                <i class="bi bi-people fs-5"></i>
                <small>Friends</small>
            </a>
            <a asp-action="Servers" class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="servers">
                <i class="bi bi-hdd-stack fs-5"></i>
                <small>Servers</small>
            </a>
            <a class="btn btn-dark d-flex flex-column align-items-center text-secondary" data-page="settings">
                <i class="bi bi-gear fs-5"></i>
                <small>Settings</small>
            </a>
        </div>
    </div>
</nav>
