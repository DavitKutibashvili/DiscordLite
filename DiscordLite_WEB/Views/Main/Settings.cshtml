@using DiscordLite_DTO
@using DiscordLite_Utility
@{
    ViewData["Title"] = "Discord Lite - Settings";
}
@model UserDTO

<div id="friends-page">
    <div style="margin: 0 10%;">
        <h1 class="dl-page-title">Settings</h1>

        <!-- Profile Card -->
        <div class="dl-friend-card mb-4">
            <div class="dl-avatar-wrap">
                <img src="@SD.GetImageUrl(Model.AvatarUrl)" alt="Avatar" class="dl-avatar" />
                <span class="dl-presence" data-user-id="@Model.Id"></span>
            </div>
            <div class="dl-friend-info">
                <div class="dl-friend-name">@Model.DisplayName</div>
                <div class="dl-friend-sub">@Model.UserName</div>
            </div>
        </div>

        <!-- Settings Items -->
        <p class="dl-section-label">Preferences</p>

        <a asp-controller="Main" asp-action="AccountDetails" class="dl-friend-card text-decoration-none">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Account Details</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </a>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Notifications</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Privacy</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Appearance</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">About</div>
            </div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <hr class="dl-divider" />

        <a asp-controller="Auth" asp-action="Logout" class="dl-btn-primary w-100 text-center text-decoration-none d-block py-2" style="background: var(--dl-danger);">
            Log Out
        </a>
    </div>
</div>

<nav class="bottom-nav">
    <div class="nav-inner">
        <a asp-action="Index" class="nav-item">
            <i class="bi bi-chat-dots"></i>
            <span>Chats</span>
        </a>
        <a asp-action="Friends" class="nav-item">
            <i class="bi bi-people-fill"></i>
            <span>Friends</span>
        </a>
        <a asp-action="Servers" class="nav-item">
            <i class="bi bi-hdd-stack"></i>
            <span>Servers</span>
        </a>
        <a class="nav-item active">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </div>
</nav>