@using DiscordLite_DTO
@{
    ViewData["Title"] = "Discord Lite - Servers";
}
@model List<ServerDTO>

<div id="friends-page">
    <div style="margin: 0 10%;">
        <h1 class="dl-page-title">Servers</h1>
        @if (TempData["success"] != null)
        {
            <div class="dl-alert dl-alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["success"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="dl-alert dl-alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                @TempData["error"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }
        <p class="dl-section-label">Your Servers</p>

        <!-- Create / Join actions -->
        <div class="d-flex gap-2 mb-4">
            <form asp-action="CreateServer" method="post" class="flex-grow-1 d-flex gap-2">
                <input type="text" name="name" class="dl-input" placeholder="Server name" required />
                <button type="submit" class="dl-btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Create
                </button>
            </form>

            <form asp-action="JoinServer" method="post" class="flex-grow-1 d-flex gap-2">
                <input type="text" name="inviteCode" class="dl-input" placeholder="Invite code" required />
                <button type="submit" class="dl-btn-primary" style="background: var(--dl-surface); border: 1px solid var(--dl-border); color: var(--dl-text);">
                    <i class="bi bi-link-45deg me-1"></i>Join
                </button>
            </form>
        </div>

        <!-- Placeholder server card -->
        @foreach (var server in Model)
        {
            <a asp-action="Server" asp-route-id="@server.Id" class="dl-friend-card text-decoration-none">
                <div class="dl-avatar-wrap">
                    <div class="dl-avatar d-flex align-items-center justify-content-center fw-bold" style="background: #ed4245; color: #fff; border-radius: 30%;">
                        G
                    </div>
                </div>
                <div class="dl-friend-info">
                    <div class="dl-friend-name">@server.Name</div>
                    <div class="dl-friend-sub">128 members</div>
                </div>
                <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
            </a>
        }
    </div>
</div>

<nav class="bottom-nav">
    <div class="nav-inner">
        <a asp-controller="Chat" class="nav-item">
            <i class="bi bi-chat-dots"></i>
            <span>Chats</span>
        </a>
        <a asp-controller="Friend" class="nav-item">
            <i class="bi bi-people-fill"></i>
            <span>Friends</span>
        </a>
        <a class="nav-item active">
            <i class="bi bi-hdd-stack"></i>
            <span>Servers</span>
        </a>
        <a asp-controller="Setting" class="nav-item">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </div>
</nav>