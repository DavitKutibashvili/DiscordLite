@using DiscordLite_DTO
@using DiscordLite_Utility
@{
    ViewData["Title"] = "Discord Lite - Account Details";
}
@model UserDTO

<div id="friends-page">
    <div style="margin: 0 10%;">

        <!-- Header -->
        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-action="Index" style="color: var(--dl-muted); text-decoration: none; font-size: 1.3rem;">
                <i class="bi bi-chevron-left"></i>
            </a>
            <h1 class="dl-page-title mb-0">Account Details</h1>
        </div>

        <!-- Alerts -->
        @if (TempData["success"] != null)
        {
            <div class="dl-alert dl-alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["success"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["error"] != null)
        {
            <div class="dl-alert dl-alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                @TempData["error"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Avatar Section -->
        <p class="dl-section-label">Profile Picture</p>
        <div class="dl-friend-card mb-4" style="flex-direction: column; align-items: flex-start; gap: 1rem;">
            <div class="d-flex align-items-center gap-3">
                <div class="dl-avatar-wrap">
                    <img id="avatarPreview" src="@SD.GetImageUrl(Model.AvatarUrl!)" alt="Avatar" class="dl-avatar" />
                </div>
                <div>
                    <div class="dl-friend-name">Profile Picture</div>
                    <div class="dl-friend-sub">JPG or PNG, max 5MB</div>
                </div>
            </div>
            <form asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" class="w-100">
                <input type="file" id="avatarInput" name="file" accept=".jpg,.jpeg,.png" class="d-none" />
                <div class="d-flex gap-2">
                    <button type="button" class="dl-btn-primary flex-grow-1" onclick="document.getElementById('avatarInput').click()">
                        <i class="bi bi-upload me-1"></i>Change Photo
                    </button>
                    <button type="submit" id="saveAvatarBtn" class="dl-btn-primary d-none" style="background: var(--dl-success);">
                        <i class="bi bi-check me-1"></i>Save
                    </button>
                </div>
            </form>
            <div id="avatarToast" class="d-none small rounded-2 px-2 py-1"></div>
        </div>

        <!-- Account Fields -->
        <p class="dl-section-label">Account</p>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Username</div>
            </div>
            <div class="dl-friend-sub">@Model.UserName</div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card" style="flex-wrap: wrap;">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Display Name</div>
            </div>
            <div id="displayname-view" class="d-flex align-items-center gap-2">
                <span class="dl-friend-sub">@Model.DisplayName</span>
                <i class="bi bi-pencil" style="color: var(--dl-muted); cursor:pointer;" onclick="toggleDisplayNameEdit()"></i>
            </div>
            <form asp-action="UpdateDisplayName" method="post" id="displayname-form" class="d-none d-flex align-items-center gap-2 w-100 mt-2">
                <input type="text" name="newDisplayName" value="@Model.DisplayName" class="dl-input" style="max-width: 200px;" maxlength="32" />
                <button type="submit" class="dl-btn-primary">Save</button>
                <button type="button" class="dl-btn-primary" style="background: var(--dl-surface-hover);" onclick="toggleDisplayNameEdit()">Cancel</button>
            </form>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Email</div>
            </div>
            <div class="dl-friend-sub">john@example.com</div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Phone Number</div>
            </div>
            <div class="dl-friend-sub">Not set</div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <div class="dl-friend-card">
            <div class="dl-friend-info">
                <div class="dl-friend-name">Password</div>
            </div>
            <div class="dl-friend-sub">••••••••</div>
            <i class="bi bi-chevron-right" style="color: var(--dl-muted);"></i>
        </div>

        <hr class="dl-divider" />

        <button class="dl-btn-primary w-100 py-2" style="background: transparent; border: 1px solid var(--dl-danger); color: var(--dl-danger);">
            Delete Account
        </button>

    </div>
</div>

<nav class="bottom-nav">
    <div class="nav-inner">
        <a asp-controller="Chat" class="nav-item">
            <i class="bi bi-chat-dots"></i>
            <span>Chats</span>
        </a>
        <a asp-controller="Friend" class="nav-item">
            <i class="bi bi-people-fill"></i>
            <span>Friends</span>
        </a>
        <a asp-controller="Server" class="nav-item">
            <i class="bi bi-hdd-stack"></i>
            <span>Servers</span>
        </a>
        <a asp-controller="Setting" class="nav-item active">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </div>
</nav>

@section Scripts {
    <script>
        document.getElementById('avatarInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;

            const allowed = ['image/jpeg', 'image/png'];
            if (!allowed.includes(file.type)) { showToast('Only JPG and PNG allowed.', false); return; }
            if (file.size > 5 * 1024 * 1024) { showToast('File exceeds 5MB.', false); return; }

            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('avatarPreview').src = e.target.result;
                document.getElementById('saveAvatarBtn').classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        });

        function showToast(msg, success) {
            const t = document.getElementById('avatarToast');
            t.textContent = msg;
            t.className = `mt-2 small rounded-2 px-2 py-1 ${success ? 'bg-success bg-opacity-25 text-success' : 'bg-danger bg-opacity-25 text-danger'}`;
            t.classList.remove('d-none');
            setTimeout(() => t.classList.add('d-none'), 4000);
        }

        function toggleDisplayNameEdit() {
            document.getElementById('displayname-view').classList.toggle('d-none');
            document.getElementById('displayname-form').classList.toggle('d-none');
        }
    </script>
}